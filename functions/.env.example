# Environment Variables Template for Firebase Functions
# Copy this to .env.local and fill in your values

# Gmail Configuration (for sending emails)
ADMIN_EMAIL=your-admin-email@gmail.com
ADMIN_EMAIL_PASSWORD=your-app-specific-password

# Google Cloud Configuration (auto-configured by Firebase)
# GCLOUD_PROJECT=quraan-dd543

# Notes:
# 1. Generate Gmail App Password:
#    - Go to: https://myaccount.google.com/apppasswords
#    - Select "Mail" and "Windows Computer"
#    - Copy the 16-character password
#    - Paste here
# 
# 2. Keep .env.local in .gitignore (never commit credentials)
#
# 3. For local development:
#    firebase emulators:start --only functions
#
# 4. For production deployment:
#    firebase deploy --only functions
