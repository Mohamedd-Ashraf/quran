<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <uses-permission android:name="android.permission.VIBRATE" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.USE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />
    <!-- Required on Android 14+ for download progress notifications -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />
    <uses-permission android:name="android.permission.SET_TIME" />
    <uses-permission android:name="android.permission.INTERNET" />
    <!-- Required to change ringer mode / enable Do-Not-Disturb during prayer -->
    <uses-permission android:name="android.permission.ACCESS_NOTIFICATION_POLICY" />
    <application
        android:label="@string/app_name"
        android:name="${applicationName}"
        android:icon="@mipmap/launcher_icon"
        android:networkSecurityConfig="@xml/network_security_config">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">
            <!-- Specifies an Android theme to apply to this Activity as soon as
                 the Android process has started. This theme is visible to the user
                 while the Flutter UI initializes. After that, this theme continues
                 to determine the Window background behind the Flutter UI. -->
            <meta-data
              android:name="io.flutter.embedding.android.NormalTheme"
              android:resource="@style/NormalTheme"
              />
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>
        <!-- Don't delete the meta-data below.
             This is used by the Flutter tool to generate GeneratedPluginRegistrant.java -->
        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />
        <!-- Impeller/Vulkan causes GPU surface-area crashes on some devices (e.g.,
             Samsung SM-A165F whose GPU caps surface area at 2MP while the screen is 2.5MP).
             Disable Impeller so Flutter falls back to OpenGL/SKIA on such devices. -->
        <meta-data
            android:name="io.flutter.embedding.android.EnableImpeller"
            android:value="false" />

        <!-- Adhan foreground service — plays audio when app is closed -->
        <service
            android:name=".AdhanPlayerService"
            android:foregroundServiceType="mediaPlayback"
            android:exported="false" />

        <!-- just_audio_background: keeps Quran audio alive with screen off -->
        <service
            android:name="com.ryanheise.audioservice.AudioService"
            android:foregroundServiceType="mediaPlayback"
            android:exported="true">
            <intent-filter>
                <action android:name="android.media.browse.MediaBrowserService" />
            </intent-filter>
        </service>
        <receiver
            android:name="com.ryanheise.audioservice.MediaButtonReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MEDIA_BUTTON" />
            </intent-filter>
        </receiver>

        <!-- Adhan alarm receiver — wakes app at prayer time + reschedules after reboot -->
        <receiver
            android:name=".AdhanAlarmReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.example.quraan.ADHAN_FIRE" />
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
                <action android:name="android.intent.action.QUICKBOOT_POWERON" />
                <action android:name="com.htc.intent.action.QUICKBOOT_POWERON" />
                <action android:name="android.intent.action.TIME_SET" />
                <action android:name="android.intent.action.TIMEZONE_CHANGED" />
            </intent-filter>
        </receiver>

        <!-- Iqama alarm receiver — fires full iqama sound via AdhanPlayerService -->
        <receiver
            android:name=".IqamaAlarmReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.example.quraan.IQAMA_FIRE" />
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
                <action android:name="android.intent.action.QUICKBOOT_POWERON" />
                <action android:name="com.htc.intent.action.QUICKBOOT_POWERON" />
                <action android:name="android.intent.action.TIME_SET" />
                <action android:name="android.intent.action.TIMEZONE_CHANGED" />
            </intent-filter>
        </receiver>

        <!-- Approaching-reminder alarm receiver — fires prayer-specific reminder sound via AdhanPlayerService -->
        <receiver
            android:name=".ApproachingAlarmReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.example.quraan.APPROACHING_FIRE" />
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
                <action android:name="android.intent.action.QUICKBOOT_POWERON" />
                <action android:name="com.htc.intent.action.QUICKBOOT_POWERON" />
                <action android:name="android.intent.action.TIME_SET" />
                <action android:name="android.intent.action.TIMEZONE_CHANGED" />
            </intent-filter>
        </receiver>

        <!-- Salawat alarm receiver — fires salawat sound via AdhanPlayerService -->
        <receiver
            android:name=".SalawatAlarmReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.example.quraan.SALAWAT_FIRE" />
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
                <action android:name="android.intent.action.QUICKBOOT_POWERON" />
                <action android:name="com.htc.intent.action.QUICKBOOT_POWERON" />
                <action android:name="android.intent.action.TIME_SET" />
                <action android:name="android.intent.action.TIMEZONE_CHANGED" />
            </intent-filter>
        </receiver>

        <!-- Silent mode receiver — silences phone during prayer and restores ringer afterwards -->
        <receiver
            android:name=".SilentModeAlarmReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.example.quraan.SILENT_MODE_START" />
                <action android:name="com.example.quraan.SILENT_MODE_END" />
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
                <action android:name="android.intent.action.QUICKBOOT_POWERON" />
                <action android:name="com.htc.intent.action.QUICKBOOT_POWERON" />
                <action android:name="android.intent.action.TIME_SET" />
                <action android:name="android.intent.action.TIMEZONE_CHANGED" />
            </intent-filter>
        </receiver>

        <!-- flutter_local_notifications scheduled notification receivers -->
        <receiver
            android:name="com.dexterous.flutterlocalnotifications.ScheduledNotificationReceiver"
            android:exported="false" />
        <receiver
            android:name="com.dexterous.flutterlocalnotifications.ScheduledNotificationBootReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
                <action android:name="android.intent.action.QUICKBOOT_POWERON" />
                <action android:name="com.htc.intent.action.QUICKBOOT_POWERON" />
            </intent-filter>
        </receiver>

        <!-- ═══════════════════════════════════════════════════════════════════
             Prayer Times & Tasbeeh Home-Screen Widgets
             Order: Dark → Normal → Light  (each pair: Prayer then Tasbeeh)
             ═══════════════════════════════════════════════════════════════════ -->

        <!-- 1 ── مواقيت الصلاة (داكن) -->
        <receiver
            android:name=".PrayerTimesWidgetDark"
            android:exported="true"
            android:label="@string/prayer_widget_dark_label">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
                <action android:name="android.intent.action.QUICKBOOT_POWERON" />
                <action android:name="com.htc.intent.action.QUICKBOOT_POWERON" />
                <action android:name="android.intent.action.USER_PRESENT" />
                <action android:name="com.example.quraan.ADHAN_STARTED" />
                <action android:name="com.example.quraan.PRAYER_WIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/prayer_widget_dark_info" />
        </receiver>

        <!-- 2 ── السبحة (داكن) -->
        <receiver
            android:name=".TasbeehWidgetDark"
            android:exported="true"
            android:label="@string/tasbeeh_widget_dark_label">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
                <action android:name="com.example.quraan.TASBEEH_INCREMENT" />
                <action android:name="com.example.quraan.TASBEEH_RESET" />
                <action android:name="com.example.quraan.TASBEEH_NEXT" />
                <action android:name="com.example.quraan.TASBEEH_WIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/tasbeeh_widget_dark_info" />
        </receiver>

        <!-- 3 ── مواقيت الصلاة (عادي) -->
        <receiver
            android:name=".PrayerTimesWidget"
            android:exported="true"
            android:label="@string/prayer_widget_label">
            <intent-filter>
                <!-- Required: system asks the widget provider to update -->
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <!-- Refresh after device reboot / package replace -->
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
                <action android:name="android.intent.action.QUICKBOOT_POWERON" />
                <action android:name="com.htc.intent.action.QUICKBOOT_POWERON" />
                <!-- Refresh when screen unlocks -->
                <action android:name="android.intent.action.USER_PRESENT" />
                <!-- Refresh when adhan starts -->
                <action android:name="com.example.quraan.ADHAN_STARTED" />
                <!-- Custom 1-minute refresh alarm -->
                <action android:name="com.example.quraan.PRAYER_WIDGET_UPDATE" />
            </intent-filter>
            <!-- Widget metadata -->
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/prayer_widget_info" />
        </receiver>

        <!-- 4 ── السبحة (عادي) -->
        <receiver
            android:name=".TasbeehWidget"
            android:exported="true"
            android:label="@string/tasbeeh_widget_label">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
                <action android:name="com.example.quraan.TASBEEH_INCREMENT" />
                <action android:name="com.example.quraan.TASBEEH_RESET" />
                <action android:name="com.example.quraan.TASBEEH_NEXT" />
                <action android:name="com.example.quraan.TASBEEH_WIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/tasbeeh_widget_info" />
        </receiver>

        <!-- 5 ── مواقيت الصلاة (فاتح) -->
        <receiver
            android:name=".PrayerTimesWidgetLight"
            android:exported="true"
            android:label="@string/prayer_widget_light_label">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
                <action android:name="android.intent.action.QUICKBOOT_POWERON" />
                <action android:name="com.htc.intent.action.QUICKBOOT_POWERON" />
                <action android:name="android.intent.action.USER_PRESENT" />
                <action android:name="com.example.quraan.ADHAN_STARTED" />
                <action android:name="com.example.quraan.PRAYER_WIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/prayer_widget_light_info" />
        </receiver>

        <!-- 6 ── السبحة (فاتح) -->
        <receiver
            android:name=".TasbeehWidgetLight"
            android:exported="true"
            android:label="@string/tasbeeh_widget_light_label">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
                <action android:name="com.example.quraan.TASBEEH_INCREMENT" />
                <action android:name="com.example.quraan.TASBEEH_RESET" />
                <action android:name="com.example.quraan.TASBEEH_NEXT" />
                <action android:name="com.example.quraan.TASBEEH_WIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/tasbeeh_widget_light_info" />
        </receiver>

        <!-- 7 ── أذكار الصلاة (داكن) -->
        <receiver
            android:name=".AdhkarWidgetDark"
            android:exported="true"
            android:label="@string/adhkar_widget_dark_label">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
                <action android:name="android.intent.action.QUICKBOOT_POWERON" />
                <action android:name="com.htc.intent.action.QUICKBOOT_POWERON" />
                <action android:name="com.example.quraan.ADHAN_STARTED" />
                <action android:name="com.example.quraan.ADHKAR_WIDGET_TAP" />
                <action android:name="com.example.quraan.ADHKAR_WIDGET_RESET" />
                <action android:name="com.example.quraan.ADHKAR_WIDGET_UPDATE" />
                <action android:name="com.example.quraan.ADHKAR_WIDGET_AUTO_ADVANCE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/adhkar_widget_dark_info" />
        </receiver>

        <!-- 8 ── أذكار الصلاة (عادي) -->
        <receiver
            android:name=".AdhkarWidget"
            android:exported="true"
            android:label="@string/adhkar_widget_label">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
                <action android:name="android.intent.action.QUICKBOOT_POWERON" />
                <action android:name="com.htc.intent.action.QUICKBOOT_POWERON" />
                <action android:name="com.example.quraan.ADHAN_STARTED" />
                <action android:name="com.example.quraan.ADHKAR_WIDGET_TAP" />
                <action android:name="com.example.quraan.ADHKAR_WIDGET_RESET" />
                <action android:name="com.example.quraan.ADHKAR_WIDGET_UPDATE" />
                <action android:name="com.example.quraan.ADHKAR_WIDGET_AUTO_ADVANCE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/adhkar_widget_info" />
        </receiver>

        <!-- 9 ── أذكار الصلاة (فاتح) -->
        <receiver
            android:name=".AdhkarWidgetLight"
            android:exported="true"
            android:label="@string/adhkar_widget_light_label">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
                <action android:name="android.intent.action.QUICKBOOT_POWERON" />
                <action android:name="com.htc.intent.action.QUICKBOOT_POWERON" />
                <action android:name="com.example.quraan.ADHAN_STARTED" />
                <action android:name="com.example.quraan.ADHKAR_WIDGET_TAP" />
                <action android:name="com.example.quraan.ADHKAR_WIDGET_RESET" />
                <action android:name="com.example.quraan.ADHKAR_WIDGET_UPDATE" />
                <action android:name="com.example.quraan.ADHKAR_WIDGET_AUTO_ADVANCE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/adhkar_widget_light_info" />
        </receiver>
    </application>
    <!-- Required to query activities that can process text, see:
         https://developer.android.com/training/package-visibility and
         https://developer.android.com/reference/android/content/Intent#ACTION_PROCESS_TEXT.

         In particular, this is used by the Flutter engine in io.flutter.plugin.text.ProcessTextPlugin. -->
    <queries>
        <intent>
            <action android:name="android.intent.action.PROCESS_TEXT"/>
            <data android:mimeType="text/plain"/>
        </intent>
        <intent>
            <action android:name="android.intent.action.VIEW"/>
            <data android:scheme="https"/>
        </intent>
    </queries>
</manifest>
