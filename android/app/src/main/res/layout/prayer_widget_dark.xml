<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_bg_dark"
    android:orientation="vertical"
    android:padding="8dp">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical">
        <TextView android:id="@+id/widget_title" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="نور الإيمان" android:textColor="#FFE8EFEA" android:textSize="11sp" android:textStyle="bold" />
        <TextView android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1" android:text="" />
        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical" android:gravity="end">
            <TextView android:id="@+id/widget_date" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="—" android:textColor="#CCDEE6EB" android:textSize="9sp" />
            <TextView android:id="@+id/widget_hijri_date" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:text="—" android:textColor="#99DEE6EB" android:textSize="8sp" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout android:id="@+id/next_card" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:background="@drawable/widget_card_next_dark" android:orientation="horizontal" android:padding="7dp" android:gravity="center_vertical">
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
            <TextView android:id="@+id/next_prayer_countdown" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="—" android:textColor="#FF9FD5C0" android:textSize="15sp" android:textStyle="bold" />
            <TextView android:id="@+id/label_next_prayer" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:text="القادمة" android:textColor="#CCDEE6EB" android:textSize="7sp" />
        </LinearLayout>
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="end">
            <TextView android:id="@+id/next_prayer_name" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="—" android:textColor="#FFF1F5F8" android:textSize="20sp" android:textStyle="bold" />
            <TextView android:id="@+id/next_prayer_time" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="1dp" android:text="—" android:textColor="#99DEE6EB" android:textSize="9sp" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:orientation="horizontal" android:gravity="center">
        <LinearLayout android:id="@+id/fajr_col" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center" android:padding="2dp"><TextView android:id="@+id/fajr_badge" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="الآن" android:textColor="#FF0F171C" android:textSize="7sp" android:textStyle="bold" android:paddingLeft="6dp" android:paddingTop="2dp" android:paddingRight="6dp" android:paddingBottom="2dp" android:visibility="gone" /><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:text="الفجر" android:textColor="#B3DEE6EB" android:textSize="8sp" /><TextView android:id="@+id/fajr_time" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="—" android:textColor="#FFE9EEF2" android:textSize="10sp" android:textStyle="bold" /></LinearLayout>
        <LinearLayout android:id="@+id/dhuhr_col" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center" android:padding="2dp"><TextView android:id="@+id/dhuhr_badge" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="الآن" android:textColor="#FF0F171C" android:textSize="7sp" android:textStyle="bold" android:paddingLeft="6dp" android:paddingTop="2dp" android:paddingRight="6dp" android:paddingBottom="2dp" android:visibility="gone" /><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:text="الظهر" android:textColor="#B3DEE6EB" android:textSize="8sp" /><TextView android:id="@+id/dhuhr_time" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="—" android:textColor="#FFE9EEF2" android:textSize="10sp" android:textStyle="bold" /></LinearLayout>
        <LinearLayout android:id="@+id/asr_col" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center" android:padding="2dp"><TextView android:id="@+id/asr_badge" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="الآن" android:textColor="#FF0F171C" android:textSize="7sp" android:textStyle="bold" android:paddingLeft="6dp" android:paddingTop="2dp" android:paddingRight="6dp" android:paddingBottom="2dp" android:visibility="gone" /><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:text="العصر" android:textColor="#B3DEE6EB" android:textSize="8sp" /><TextView android:id="@+id/asr_time" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="—" android:textColor="#FFE9EEF2" android:textSize="10sp" android:textStyle="bold" /></LinearLayout>
        <LinearLayout android:id="@+id/maghrib_col" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center" android:padding="2dp"><TextView android:id="@+id/maghrib_badge" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="الآن" android:textColor="#FF0F171C" android:textSize="7sp" android:textStyle="bold" android:paddingLeft="6dp" android:paddingTop="2dp" android:paddingRight="6dp" android:paddingBottom="2dp" android:visibility="gone" /><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:text="المغرب" android:textColor="#B3DEE6EB" android:textSize="8sp" /><TextView android:id="@+id/maghrib_time" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="—" android:textColor="#FFE9EEF2" android:textSize="10sp" android:textStyle="bold" /></LinearLayout>
        <LinearLayout android:id="@+id/isha_col" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center" android:padding="2dp"><TextView android:id="@+id/isha_badge" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="الآن" android:textColor="#FF0F171C" android:textSize="7sp" android:textStyle="bold" android:paddingLeft="6dp" android:paddingTop="2dp" android:paddingRight="6dp" android:paddingBottom="2dp" android:visibility="gone" /><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:text="العشاء" android:textColor="#B3DEE6EB" android:textSize="8sp" /><TextView android:id="@+id/isha_time" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="—" android:textColor="#FFE9EEF2" android:textSize="10sp" android:textStyle="bold" /></LinearLayout>
    </LinearLayout>
</LinearLayout>