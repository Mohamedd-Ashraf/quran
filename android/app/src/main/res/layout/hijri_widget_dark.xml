        <TextView android:id="@+id/d_r5c4" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:textColor="#CCFFFFFF" android:textSize="10sp"/>
        <TextView android:id="@+id/d_r5c5" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:textColor="#CCFFFFFF" android:textSize="10sp"/>
        <TextView android:id="@+id/d_r5c6" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:textColor="#CCFFFFFF" android:textSize="10sp"/>
