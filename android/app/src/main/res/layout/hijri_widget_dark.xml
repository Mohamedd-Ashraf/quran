        <TextView android:id="@+id/d_r2c6" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:textColor="#CCFFFFFF" android:textSize="10sp"/>
        <TextView android:id="@+id/d_r2c7" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:textColor="#CCFFFFFF" android:textSize="10sp"/>
    </LinearLayout>
    <!-- Row 3 -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:orientation="horizontal" android:gravity="center">
        <TextView android:id="@+id/d_r3c1" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:textColor="#CCFFFFFF" android:textSize="10sp"/>
        <TextView android:id="@+id/d_r3c2" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:textColor="#CCFFFFFF" android:textSize="10sp"/>
        <TextView android:id="@+id/d_r3c3" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:textColor="#CCFFFFFF" android:textSize="10sp"/>
        <TextView android:id="@+id/d_r3c4" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:textColor="#CCFFFFFF" android:textSize="10sp"/>
        <TextView android:id="@+id/d_r3c5" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:textColor="#CCFFFFFF" android:textSize="10sp"/>
        <TextView android:id="@+id/d_r3c6" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:textColor="#CCFFFFFF" android:textSize="10sp"/>
        <TextView android:id="@+id/d_r3c7" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:textColor="#CCFFFFFF" android:textSize="10sp"/>
