        <TextView android:id="@+id/d_r4c4" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:textColor="#CCFFFFFF" android:textSize="10sp"/>
        <TextView android:id="@+id/d_r4c5" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:textColor="#CCFFFFFF" android:textSize="10sp"/>
        <TextView android:id="@+id/d_r4c6" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:textColor="#CCFFFFFF" android:textSize="10sp"/>
        <TextView android:id="@+id/d_r4c7" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:textColor="#CCFFFFFF" android:textSize="10sp"/>
    </LinearLayout>
    <!-- Row 5 -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:orientation="horizontal" android:gravity="center">
        <TextView android:id="@+id/d_r5c1" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:textColor="#CCFFFFFF" android:textSize="10sp"/>
        <TextView android:id="@+id/d_r5c2" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:textColor="#CCFFFFFF" android:textSize="10sp"/>
