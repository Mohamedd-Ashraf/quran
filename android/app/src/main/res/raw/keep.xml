<?xml version="1.0" encoding="utf-8"?>
<!--
  Prevents the Android resource shrinker from removing adhan audio files.
  All files here are referenced dynamically (via resources.getIdentifier or
  RawResourceAndroidNotificationSound) and must be explicitly kept.

  Removed: iqama_sound.mp3 (replaced by iqama_sound_new.m4a) and
           salawat_sound.wav (not referenced in any code path).
-->
<resources xmlns:tools="http://schemas.android.com/tools"
    tools:keep="@raw/adhan_1,@raw/wird_reminder,
               @raw/iqama_sound_full,@raw/iqama_sound_new,
               @raw/short_adhan,
               @raw/prayer_approaching_dhuhr,@raw/prayer_approaching_maghrib,
               @raw/prayer_reminder_fajr,@raw/prayer_reminder_dhuhr,
               @raw/prayer_reminder_asr,@raw/prayer_reminder_maghrib,@raw/prayer_reminder_isha,
               @raw/salawat_1,@raw/salawat_2,@raw/salawat_3,@raw/salawat_4,@raw/salawat_5" />
