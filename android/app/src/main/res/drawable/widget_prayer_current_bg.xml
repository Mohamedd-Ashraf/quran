<?xml version="1.0" encoding="utf-8"?>
<!--
    Background for the currently-active prayer cell in the bottom strip.
    A gold-tinted rectangle with rounded corners to highlight the active prayer.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="#45D4AF37" />
    <corners android:radius="8dp" />
    <stroke android:width="1dp" android:color="#80D4AF37" />
</shape>
