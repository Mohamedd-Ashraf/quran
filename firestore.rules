rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function validLeaderboardPreferenceFields() {
      return (!('showInLeaderboard' in request.resource.data)
              || request.resource.data.showInLeaderboard is bool)
          && (!('lastVisibilityToggleAt' in request.resource.data)
              || request.resource.data.lastVisibilityToggleAt is timestamp)
          && (!('name' in request.resource.data)
              || request.resource.data.name is string);
    }

    // ── User data ─────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if request.auth != null
        && request.auth.uid == userId;

      allow write: if request.auth != null
        && request.auth.uid == userId
        && validLeaderboardPreferenceFields();

      match /data/{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // ── Hadith data (public read-only) ────────────────────────────────────
    match /hadith_data/{document=**} {
      allow read: if true;
      allow write: if false;
    }

    // ── Quiz leaderboard ──────────────────────────────────────────────────
    //
    // Any authenticated user can READ the full leaderboard.
    // Each user can only WRITE their own document (uid == docId).
    // Bot documents (bot_01 … bot_15) are written exclusively via the
    // Admin SDK which bypasses security rules entirely.
    //
    // Anti-cheat: every write is validated field-by-field to prevent
    // score manipulation via direct Firestore API access.
    match /quiz_leaderboard/{docId} {
      allow get, list: if request.auth != null;

      // Delete is never allowed (no rule = denied by default).

      // ── CREATE: first-time document (fresh authenticated start) ──────
      // Score counters must be zeroed — score history from guest
      // SharedPrefs is NOT migrated to prevent data inflation attacks
      // (a rooted device can modify SharedPrefs before first sign-in).
      // Only userSeed and question history are preserved client-side.
      allow create: if request.auth != null
        && request.auth.uid == docId
        // All counters must start at zero.
        && request.resource.data.totalScore == 0
        && request.resource.data.streak == 0
        && request.resource.data.correctAnswers == 0
        && request.resource.data.totalAnswered == 0
        // userSeed must be a valid integer.
        && request.resource.data.userSeed is int
        && request.resource.data.isAnonymous is bool
        && request.resource.data.cachedDisplayName is string
        // Server timestamp required.
        && request.resource.data.lastUpdated == request.time;

      // ── UPDATE: privacy fields OR answering a question ────────────
      allow update: if request.auth != null
        && request.auth.uid == docId
        // ── Server timestamp required ─────────────────────────────
        && request.resource.data.lastUpdated == request.time
        && (
          // Privacy-only edit (instant toggle): allow only display fields.
          (
            request.resource.data.diff(resource.data).changedKeys().hasOnly([
              'displayName',
              'cachedDisplayName',
              'isAnonymous',
              'photoUrl',
              'lastUpdated'
            ])
            && request.resource.data.isAnonymous is bool
            && request.resource.data.cachedDisplayName is string
          )
          ||
          (
            // ── New UTC calendar day required (server time) ───────────
            // Dividing epoch-milliseconds by 86400000 gives the UTC day
            // number (integer division truncates). Requiring the new day
            // number to be strictly greater than the stored one means the
            // server clock has crossed midnight UTC — exactly one answer
            // per calendar day, regardless of device-clock manipulation.
            // A user answering at 23:55 may answer again at 00:01 the next
            // day; advancing the device clock by any amount is irrelevant
            // because request.time is the Firestore server clock.
            (!('lastAnsweredTimestamp' in resource.data)
              || (request.time.toMillis() / 86400000)
                 > (resource.data.lastAnsweredTimestamp.toMillis() / 86400000))
            && request.resource.data.lastAnsweredTimestamp == request.time
            // ── totalAnswered must increase by exactly 1 ──────────────
            && request.resource.data.totalAnswered is int
            && request.resource.data.totalAnswered == resource.data.get('totalAnswered', 0) + 1
            // ── Score increase bounded to valid points (0,5,10,20) ────
            && request.resource.data.totalScore is int
            && request.resource.data.totalScore >= resource.data.get('totalScore', 0)
            && (request.resource.data.totalScore - resource.data.get('totalScore', 0)) in [0, 5, 10, 20]
            // ── correctAnswers consistency ────────────────────────────
            // Wrong answer (score unchanged) → correctAnswers unchanged
            // Correct answer (score increased) → correctAnswers + 1
            && request.resource.data.correctAnswers is int
            && (
              (request.resource.data.totalScore == resource.data.get('totalScore', 0)
                && request.resource.data.correctAnswers == resource.data.get('correctAnswers', 0))
              ||
              (request.resource.data.totalScore > resource.data.get('totalScore', 0)
                && request.resource.data.correctAnswers == resource.data.get('correctAnswers', 0) + 1)
            )
            // ── Streak consistency ────────────────────────────────────
            // Wrong → streak = 0;  Correct → streak +1 or 1 (gap reset)
            && request.resource.data.streak is int
            && (
              (request.resource.data.totalScore == resource.data.get('totalScore', 0)
                && request.resource.data.streak == 0)
              ||
              (request.resource.data.totalScore > resource.data.get('totalScore', 0)
                && (request.resource.data.streak == resource.data.get('streak', 0) + 1
                    || request.resource.data.streak == 1))
            )
            // ── lastAnswerCorrect must match score change ─────────────
            && request.resource.data.lastAnswerCorrect == (request.resource.data.totalScore > resource.data.get('totalScore', 0))
            // ── lastAnswerPoints must match actual increase ───────────
            && request.resource.data.lastAnswerPoints == (request.resource.data.totalScore - resource.data.get('totalScore', 0))
            && request.resource.data.isAnonymous is bool
            && request.resource.data.cachedDisplayName is string
            // ── userSeed is immutable once set; allow setting it on docs
            // that pre-date the field (userSeed may be absent in old docs) ──
            && (!('userSeed' in resource.data) || request.resource.data.userSeed == resource.data.userSeed)
          )
        );
    }

    // ── Daily leaderboard snapshot (server-managed) ────────────────────────
    match /leaderboard_daily/{dateKey}/entries/{uid} {
      allow get, list: if request.auth != null;
      allow create, update, delete: if false;
    }

    // ── Quiz server-time ping (anti device-clock-cheat) ───────────────────
    // Each authenticated user can write exactly one field (ts = server time)
    // to their own document in this collection.  The Flutter client reads it
    // back immediately to learn the authoritative server UTC time, which is
    // then used instead of DateTime.now() for the daily-quiz date check.
    match /quiz_server_time/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create, update: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.keys().hasOnly(['ts'])
        && request.resource.data.ts == request.time;
    }

    // ── Public data-deletion requests (hosting form) ─────────────────────
    // Create-only endpoint used by /data-deletion-request page.
    // No read/list/update/delete from clients.
    match /data_deletion_requests/{requestId} {
      allow create: if request.resource.data.keys().hasOnly([
            'email',
            'dataTypes',
            'reason',
            'language',
            'source',
            'status',
            'app',
            'clientTimestamp',
            'userAgent',
            'createdAt'
          ])
        && request.resource.data.email is string
        && request.resource.data.email.size() >= 5
        && request.resource.data.email.size() <= 254
        && request.resource.data.email.matches('^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$')
        && request.resource.data.dataTypes is list
        && request.resource.data.dataTypes.size() > 0
        && request.resource.data.dataTypes.size() <= 5
        && request.resource.data.reason is string
        && request.resource.data.reason.size() <= 1000
        && request.resource.data.language in ['ar', 'en']
        && request.resource.data.source == 'public_data_deletion_form'
        && request.resource.data.status == 'pending'
        && request.resource.data.app == 'Quraan - Noor Al-Iman'
        && request.resource.data.clientTimestamp is string
        && request.resource.data.clientTimestamp.size() <= 64
        && request.resource.data.userAgent is string
        && request.resource.data.userAgent.size() <= 512
        && request.resource.data.createdAt == request.time;

      allow read, update, delete: if false;
    }

    // ── Feedback / suggestions ───────────────────────────────────────────
    // Public create-only endpoint used by the in-app feedback screen.
    match /feedback/{requestId} {
      allow create: if request.resource.data.keys().hasOnly([
            'type',
            'name',
            'message',
            'appVersion',
            'createdAt'
          ])
        && request.resource.data.type in ['suggestion', 'bug', 'other']
        && (!('name' in request.resource.data)
            || (request.resource.data.name is string
                && request.resource.data.name.size() <= 80))
        && request.resource.data.message is string
        && request.resource.data.message.size() >= 10
        && request.resource.data.message.size() <= 1000
        && (!('appVersion' in request.resource.data)
            || request.resource.data.appVersion is string)
        && request.resource.data.createdAt == request.time;

      allow read, update, delete: if false;
    }

// ── Account deletion requests (delete-account page – full account wipe) ──
    // Create-only endpoint used by /delete-account page.
    // No dataTypes field – always deletes everything including the Auth user.
    match /account_deletion_requests/{requestId} {
      allow create: if request.resource.data.keys().hasOnly([
            'email',
            'reason',
            'language',
            'source',
            'status',
            'app',
            'clientTimestamp',
            'userAgent',
            'createdAt'
          ])
        && request.resource.data.email is string
        && request.resource.data.email.size() >= 5
        && request.resource.data.email.size() <= 254
        && request.resource.data.email.matches('^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$')
        && request.resource.data.reason is string
        && request.resource.data.reason.size() <= 1000
        && request.resource.data.language in ['ar', 'en']
        && request.resource.data.source == 'public_account_deletion_form'
        && request.resource.data.status == 'pending'
        && request.resource.data.app == 'Quraan - Noor Al-Iman'
        && request.resource.data.clientTimestamp is string
        && request.resource.data.clientTimestamp.size() <= 64
        && request.resource.data.userAgent is string
        && request.resource.data.userAgent.size() <= 512
        && request.resource.data.createdAt == request.time;

      allow read, update, delete: if false;
    }

    // ── Practice questions (public read, admin write only) ────────────────
    // Read: anyone — practice questions are public learning content.
    // Write: only allow creation with strict field validation.
    // Collection is seeded once via admin screen and then read-only.
    match /questions_practice/{docId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.keys().hasOnly([
          'question',
          'options',
          'correctIndex',
          'category',
          'difficulty'
        ])
        && request.resource.data.question is string
        && request.resource.data.question.size() >= 10
        && request.resource.data.question.size() <= 5000
        && request.resource.data.options is list
        && request.resource.data.options.size() == 4
        && request.resource.data.options[0] is string
        && request.resource.data.options[1] is string
        && request.resource.data.options[2] is string
        && request.resource.data.options[3] is string
        && request.resource.data.correctIndex is int
        && request.resource.data.correctIndex in [0, 1, 2, 3]
        && request.resource.data.category is string
        && request.resource.data.category in ['quran', 'hadith', 'fiqh', 'seerah', 'aqeedah']
        && request.resource.data.difficulty is string
        && request.resource.data.difficulty in ['easy', 'medium', 'hard', 'expert'];
      
      allow update, delete: if false;  // Immutable after creation
    }

    // ── Question reports (create-only, no auth required) ─────────────────────
    // Any user can submit a report; no read/update/delete from clients.
    match /question_reports/{reportId} {
      allow create: if request.resource.data.keys().hasOnly([
            'questionId',
            'questionText',
            'reason',
            'note',
            'createdAt'
          ])
        && request.resource.data.questionId is string
        && request.resource.data.questionId.size() >= 1
        && request.resource.data.questionId.size() <= 200
        && request.resource.data.reason is string
        && request.resource.data.reason in [
            'wrong_answer', 'unclear', 'typo', 'duplicate', 'other'
          ]
        && request.resource.data.note is string
        && request.resource.data.note.size() <= 300
        && request.resource.data.createdAt is timestamp;

      allow read, update, delete: if false;
    }

    // ── Default: deny everything else ─────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
